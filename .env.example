# ===== QR Food Ordering — Docker Compose Env =====
# Copy to .env and fill in your values

# --- Database ---
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- Backend ---
PORT=8080
JWT_SECRET=mySuperSecretKeyForJWTTokenGenerationThatIsAtLeast256BitsLong2024
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_RESTAURANT=My Restaurant

# --- Frontend ---
# Backend URL the browser will call (must be reachable from the host machine)
VITE_API_URL=http://localhost:8080
# URL the backend allows via CORS (the address you open in your browser)
FRONTEND_URL=http://localhost:3000
